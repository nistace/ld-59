  _lines:
  - _text: "So\u2026 what do you look like?"
    _eventBefore: 1
    _characterChanges:
    - _character: 0
      _characterPosition: 2
      _await: 0
    - _character: 1
      _characterPosition: 3
      _await: 1
    _delayBefore: 0.1
    _delayAfter: 0.1
    _clip: {fileID: 8300000, guid: 350860802f7f985439a394fcf83018bd, type: 3}
    _character: 1
    _endWithAShrug: 0
  - _text: "I\u2019m a rat. I look like a rat."
    _eventBefore: 0
    _characterChanges: []
    _delayBefore: 0.1
    _delayAfter: 0.1
    _clip: {fileID: 8300000, guid: 2c7f1129cf3ca6144b427cd738617e0e, type: 3}
    _character: 0
    _endWithAShrug: 0
  - _text: A pretty handsome one, if you ask me.
    _eventBefore: 0
    _characterChanges: []
    _delayBefore: 0.1
    _delayAfter: 0.1
    _clip: {fileID: 8300000, guid: 8b9a6a49825a8104197700b0d4094cbc, type: 3}
    _character: 0
    _endWithAShrug: 0
  - _text: The developer did a great job.
    _eventBefore: 0
    _characterChanges: []
    _delayBefore: 0.1
    _delayAfter: 0.1
    _clip: {fileID: 8300000, guid: 3761994f687e8dc499b3e3ceb15c1798, type: 3}
    _character: 0
    _endWithAShrug: 0
  - _text: "I\u2019m blind. I wouldn\u2019t know."
    _eventBefore: 0
    _characterChanges: []
    _delayBefore: 0.1
    _delayAfter: 0.1
    _clip: {fileID: 8300000, guid: 529ac2ff5fb018647b0b46313707c571, type: 3}
    _character: 1
    _endWithAShrug: 0
  - _text: "You\u2019ll have to trust me."
    _eventBefore: 0
    _characterChanges: []
    _delayBefore: 0.1
    _delayAfter: 0.1
    _clip: {fileID: 8300000, guid: efa17f64decc5774498683f927079b03, type: 3}
    _character: 0
    _endWithAShrug: 0
  - _text: Alright.
    _eventBefore: 0
    _characterChanges: []
    _delayBefore: 0.1
    _delayAfter: 0.1
    _clip: {fileID: 8300000, guid: da88c84a4493e1944a8971516185319a, type: 3}
    _character: 1
    _endWithAShrug: 1
  _delayAfter: 0.1
